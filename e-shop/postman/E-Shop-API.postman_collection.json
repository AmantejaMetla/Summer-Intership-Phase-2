{
  "info": {
    "name": "E-Shop API",
    "description": "Test the gateway and all services. Base URL: http://localhost:9090",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:9090" },
    { "key": "accessToken", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "merchantRoleId", "value": "3" }
  ],
  "item": [
    {
      "name": "Gateway",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health"
          }
        },
        {
          "name": "Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/info"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  if (json.userId != null) pm.collectionVariables.set('userId', String(json.userId));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  if (json.userId != null) pm.collectionVariables.set('userId', String(json.userId));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"paste-refresh-token-here\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/refresh"
          }
        },
        {
          "name": "List roles",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/roles"
          }
        },
        {
          "name": "Assign role to user",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleId\": 2\n}"
            },
            "url": "{{baseUrl}}/api/auth/users/1/roles"
          }
        },
        {
          "name": "Assign merchant role to user",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleId\": {{merchantRoleId}}\n}"
            },
            "url": "{{baseUrl}}/api/auth/users/{{userId}}/roles"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update my profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\",\n  \"phone\": \"+1234567890\",\n  \"address\": \"123 Main St\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me"
          }
        }
      ]
    },
    {
      "name": "Product",
      "item": [
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "Get product by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/products/1"
          }
        },
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/products/categories"
          }
        },
        {
          "name": "Create category",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryName\": \"Electronics\"\n}"
            },
            "url": "{{baseUrl}}/api/products/categories"
          }
        },
        {
          "name": "List products by categoryId",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/products?categoryId=1"
          }
        },
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Widget\", \"description\": \"A widget\", \"price\": 19.99, \"category\": \"Electronics\", \"categoryId\": 1, \"stockQuantity\": 100\n}"
            },
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "List my products (merchant)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": "{{baseUrl}}/api/products/my"
          }
        },
        {
          "name": "Update product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Widget Updated\", \"description\": \"Updated\", \"price\": 24.99, \"stockQuantity\": 50\n}"
            },
            "url": "{{baseUrl}}/api/products/1"
          }
        },
        {
          "name": "Delete product",
          "request": {
            "method": "DELETE",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": "{{baseUrl}}/api/products/1"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get my cart",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": "{{baseUrl}}/api/cart"
          }
        },
        {
          "name": "Add to cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"productName\": \"Sample Product\",\n  \"quantity\": 2,\n  \"unitPrice\": 9.99\n}"
            },
            "url": "{{baseUrl}}/api/cart/items"
          }
        }
      ]
    },
    {
      "name": "Order",
      "item": [
        {
          "name": "Create order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"totalAmount\": 0,\n  \"status\": \"PENDING\"\n}"
            },
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "Get order by id",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": "{{baseUrl}}/api/orders/1"
          }
        },
        {
          "name": "Get order items",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": "{{baseUrl}}/api/orders/1/items"
          }
        },
        {
          "name": "Add order item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"quantity\": 2,\n  \"price\": 9.99\n}"
            },
            "url": "{{baseUrl}}/api/orders/1/items"
          }
        },
        {
          "name": "Merchant sales (orders containing my products)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": "{{baseUrl}}/api/orders/merchant/sales"
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "Get stock by product id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/inventory/1"
          }
        },
        {
          "name": "Update stock (merchant/admin only)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 50\n}"
            },
            "url": "{{baseUrl}}/api/inventory/1"
          }
        }
      ]
    },
    {
      "name": "Payment",
      "item": [
        {
          "name": "Create order (Razorpay)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": 1,\n  \"amount\": 299.00\n}"
            },
            "url": "{{baseUrl}}/api/payments/create-order"
          }
        },
        {
          "name": "Verify payment (Razorpay)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": 1,\n  \"razorpayOrderId\": \"order_xxx\",\n  \"razorpayPaymentId\": \"pay_xxx\",\n  \"razorpaySignature\": \"signature_from_checkout\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/verify"
          }
        },
        {
          "name": "List my payments",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": "{{baseUrl}}/api/payments"
          }
        },
        {
          "name": "Get payment by id",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": "{{baseUrl}}/api/payments/1"
          }
        }
      ]
    },
    {
      "name": "Merchant (full flow)",
      "item": [
        {
          "name": "1. List roles (get merchant id)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/roles"
          }
        },
        {
          "name": "2. Assign merchant role to user",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleId\": {{merchantRoleId}}\n}"
            },
            "url": "{{baseUrl}}/api/auth/users/{{userId}}/roles"
          }
        },
        {
          "name": "3. Create product (you become seller)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Merchant Product\", \"description\": \"Sold by me\", \"price\": 99.99, \"category\": \"Electronics\", \"categoryId\": 1, \"stockQuantity\": 10\n}"
            },
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "4. List my products",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": "{{baseUrl}}/api/products/my"
          }
        },
        {
          "name": "5. Update product (use id from step 4)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Merchant Product Updated\", \"price\": 89.99, \"stockQuantity\": 20\n}"
            },
            "url": "{{baseUrl}}/api/products/1"
          }
        },
        {
          "name": "6. Update stock for my product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 50\n}"
            },
            "url": "{{baseUrl}}/api/inventory/1"
          }
        },
        {
          "name": "7. Merchant sales (orders with my products)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": "{{baseUrl}}/api/orders/merchant/sales"
          }
        }
      ]
    }
  ]
}
