# Copy this file to "auth-service.env.local" and fill real values.
# This local file is gitignored and safe for corporate/restricted laptops.

# SMTP for OTP emails
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-login@smtp-brevo.com
SMTP_PASS=your-smtp-key
SMTP_FROM=your-verified-sender@example.com
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true

# RabbitMQ-backed OTP dispatch (optional but recommended for reliability)
# Keep disabled if RabbitMQ is not running.
OTP_RABBIT_ENABLED=false
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
OTP_RABBIT_EXCHANGE=auth.otp.exchange
OTP_RABBIT_QUEUE=auth.otp.queue
OTP_RABBIT_ROUTING_KEY=auth.otp

# SMS OTP (optional). With provider=log, SMS is logged for dev.
SMS_ENABLED=false
SMS_PROVIDER=log
# For real India SMS set provider=msg91 and fill these:
MSG91_BASE_URL=https://control.msg91.com/api/sendhttp.php
MSG91_AUTH_KEY=
MSG91_SENDER_ID=ESHOPP
MSG91_ROUTE=4
# For Twilio set provider=twilio and fill these:
TWILIO_BASE_URL=https://api.twilio.com/2010-04-01
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional backup for local development only.
# Set empty to disable bypass.
TOTP_DEV_BYPASS_CODE=000000
